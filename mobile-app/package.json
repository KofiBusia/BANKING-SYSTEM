{
  "name": "crestline-banking-app",
  "version": "1.0.0",
  "private": true,
  "description": "Crestline Solutions LTD Mobile Banking App",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build:android": "npm run build && npx cap sync android",
    "build:ios": "npm run build && npx cap sync ios",
    "gen:icons": "npx @capacitor/assets generate --iconBackgroundColor '#1B3A6B' --iconBackgroundColorDark '#0F2347' --splashBackgroundColor '#1B3A6B' --splashBackgroundColorDark '#0F2347'"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.0.0",
    "terser": "^5.30.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
